# Copy this to .env and fill in your keys

# Ara SDK (required) — get these by running: ara deploy ara_app.py
ARA_API_KEY=your_ara_api_key_here
ARA_RUNTIME_KEY=your_ara_runtime_key_here

# Email via Resend (optional) — sign up at https://resend.com
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=ThePenn <notes@yourdomain.com>
EMAIL_TO=you@email.com

# Telegram (optional) — create a bot via @BotFather, get chat_id via @userinfobot
TELEGRAM_BOT_TOKEN=123456:ABC-DEF
TELEGRAM_CHAT_ID=123456789
