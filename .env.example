# Copy this to .env and fill in your keys

# Ara SDK (required) — get these by running: ara deploy ara_app.py
ARA_API_KEY=your_ara_api_key_here
ARA_RUNTIME_KEY=your_ara_runtime_key_here

# Messaging channels (Telegram, Email, WhatsApp, iMessage) are configured
# in the Ara console at https://app.ara.so — no API keys needed here.
